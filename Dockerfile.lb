# Forward-only TCP load balancer (HAProxy). Replaces the hand-rolled
# fd-passing LB, whose blocking send_fd fallback caused a ~3.6ms p99 tail.
# mode tcp => no HTTP parsing, no detection logic, minimal latency.
FROM haproxy:2.9-alpine
COPY haproxy.cfg /usr/local/etc/haproxy/haproxy.cfg
EXPOSE 9999
